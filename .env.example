# LLM
# Used as the default key when no key is set via the UI.
# Format: provider/model-name (LiteLLM convention)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=anthropic/claude-haiku-4-5

# App
APP_ENV=development
SECRET_KEY=change_me_in_production

# Database
DATABASE_URL=sqlite:///./data/applo.db

# Scraping
# Set SCRAPER_HEADLESS=false to watch the browser during scraping (useful for debugging)
SCRAPER_HEADLESS=true
SCRAPER_DELAY_SECS=2

# Resume
MASTER_RESUME_PATH=data/resumes/master.docx

# Google
GOOGLE_SERVICE_ACCOUNT_PATH=data/google_service_account.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here